<view class="page-shell">
  <view class="top-bar tight">
    <view class="brand-lockup">
      <view class="eyebrow">SIGN IN</view>
      <view class="app-title">欢迎回来</view>
      <view class="subtitle">登录后可以点赞、发动态，并同步你的校园身份。</view>
    </view>
  </view>

  <view class="form-sheet">
    <view class="section-title">手机端快捷登录</view>
    <view class="helper-text">推荐在微信里直接使用，少输入，适合小程序场景。</view>
    <button class="wechat-action" loading="{{loading}}" bindtap="submitWechatLogin">
      使用微信登录
    </button>
  </view>

  <view class="form-sheet">
    <view class="section-title">校园账号登录</view>
    <view class="segmented flat">
      <view class="{{usernameModeClass}}" data-mode="username" bindtap="switchMode">用户名</view>
      <view class="{{emailModeClass}}" data-mode="email" bindtap="switchMode">邮箱</view>
    </view>

    <view class="field-label">{{modeLabel}}</view>
    <input
      class="text-input"
      placeholder="{{accountPlaceholder}}"
      value="{{account}}"
      data-field="account"
      bindinput="updateField"
    />

    <view class="field-label">密码</view>
    <input
      class="text-input"
      password
      placeholder="至少 6 位"
      value="{{password}}"
      data-field="password"
      bindinput="updateField"
    />

    <view class="action-row">
      <button class="primary-action" loading="{{loading}}" bindtap="submitAccountLogin">
        登录
      </button>
    </view>
  </view>
</view>
