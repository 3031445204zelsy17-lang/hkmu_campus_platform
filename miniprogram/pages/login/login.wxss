/* Login page — register/login toggle. Link styling comes from the global
   .text-link class; this just centers it and enlarges the tap target. */
.form-toggle {
  margin-top: 16rpx;
  padding: 12rpx 0;
  text-align: center;
}

/* B5 隐私声明入口 — 弱于 text-link,不抢注册切换视觉 */
.privacy-entry {
  margin-top: 8rpx;
  padding: 8rpx 0 32rpx;
  text-align: center;
  font-size: var(--fs-link);
  color: var(--text-secondary);
}

/* 用户名/邮箱切换选中态:绿底白字,覆盖全局弱 active(白底绿字+8% 淡阴影)*/
.segmented .segment-item.active {
  background: var(--green-deep);
  color: #FFFFFF;
  box-shadow: 0 8rpx 22rpx rgba(61, 122, 46, 0.18);
}
