/* Publish-form overlay.
   lostfound previously had no page wxss — the global app.wxss supplies
   field-label / text-input / text-area / segmented / segment-item /
   primary-action / secondary-action / top-action. Only the overlay shell and
   the image picker (mirrored from compose.wxss, since pages don't share wxss)
   live here. Colors use the campus design tokens. */

.form-overlay {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 950;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(20, 32, 51, 0.5);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.lost-form-sheet {
  width: 100%;
  max-height: 86vh;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  box-shadow: 0 -16rpx 48rpx rgba(30, 70, 40, 0.12);
  overflow: hidden;
}

.lost-form-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid rgba(90, 130, 90, 0.12);
}

.lost-form-title {
  color: #142033;
  font-size: 32rpx;
  font-weight: 700;
}

.lost-form-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #6B7280;
  font-size: 32rpx;
}

.lost-form-body {
  flex: 1;
  min-height: 0;
  padding: 24rpx 32rpx 8rpx;
  box-sizing: border-box;
}

.lost-form-foot {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx 36rpx;
  border-top: 1rpx solid rgba(90, 130, 90, 0.12);
}

.lost-form-foot .primary-action,
.lost-form-foot .secondary-action {
  flex: 1;
}

/* Image picker — mirrored from compose.wxss (pages don't share wxss). */
.compose-image-row {
  margin-top: 20rpx;
}

.compose-image-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 200rpx;
  background: var(--surface);
  border: 2rpx dashed var(--border-soft);
  border-radius: var(--radius-entry);
  color: var(--text-secondary);
}

.compose-image-add-glyph {
  font-size: 48rpx;
  color: var(--accent-blue);
}

.compose-image-add-label {
  font-size: var(--fs-link);
}

.compose-image-preview {
  position: relative;
  width: 100%;
  height: 200rpx;
  border-radius: var(--radius-entry);
  overflow: hidden;
}

.compose-image-thumb {
  width: 100%;
  height: 100%;
}

.compose-image-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-pill);
  background: rgba(20, 32, 51, 0.6);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-link);
}

/* Tap feedback on an existing remote image shown in edit mode (tap to replace). */
.compose-image-preview-tap {
  opacity: 0.7;
}

/* Per-card author actions (edit / mark resolved / delete).
   Only rendered on the viewer's own items (item.isMine). */
.item-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(90, 130, 90, 0.12);
}

.item-action {
  padding: 10rpx 22rpx;
  border-radius: var(--radius-pill);
  background: #EEF5EC;
  color: #3D7A2E;
  font-size: var(--fs-link);
  font-weight: 600;
  line-height: 1.4;
}

.item-action.danger {
  background: rgba(229, 72, 77, 0.1);
  color: #e5484d;
}
