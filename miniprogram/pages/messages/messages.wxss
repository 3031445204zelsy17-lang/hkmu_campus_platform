.messages {
  padding-bottom: calc(var(--shell-bottom) + env(safe-area-inset-bottom));
}

/* 工具栏:搜索 + 新私信 */
.msgs-toolbar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 14rpx var(--pad-shell) 20rpx;
}
.msgs-search {
  flex: 1;
  height: 76rpx;
  padding: 0 28rpx;
  background: var(--surface);
  border: 1rpx solid var(--border-hair);
  border-radius: var(--radius-pill);
  font-size: var(--fs-search);
  color: var(--text-primary);
  box-shadow: var(--shadow-card);
}
.msgs-new {
  flex: 0 0 auto;
  width: 76rpx;
  height: 76rpx;
  border-radius: var(--radius-pill);
  background: var(--accent-blue);
  color: #ffffff;
  font-size: 44rpx;
  line-height: 72rpx;
  text-align: center;
  box-shadow: var(--shadow-btn-primary);
}

/* 会话列表 */
.conv-list {
  padding: 0 var(--pad-shell);
}
.conv {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 24rpx 22rpx;
  margin-bottom: 14rpx;
  background: var(--surface);
  border: 1rpx solid var(--border-hair);
  border-radius: var(--radius-card-md);
  box-shadow: var(--shadow-card);
}
.conv.is-unread .conv-name {
  font-weight: 700;
}

.conv-avatar {
  position: relative;
  flex: 0 0 auto;
  width: 92rpx;
  height: 92rpx;
  border-radius: var(--radius-pill);
  overflow: hidden;
  background: var(--pill-green-bg);
  box-shadow: var(--shadow-avatar);
}
.conv-avatar-img {
  width: 100%;
  height: 100%;
}
.conv-avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--green-deep);
  font-size: 36rpx;
  font-weight: 700;
}
.conv-dot {
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: var(--radius-pill);
  background: var(--danger-text);
  border: 3rpx solid var(--surface);
}

.conv-main {
  flex: 1;
  min-width: 0;
}
.conv-row1,
.conv-row2 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}
.conv-row1 {
  margin-bottom: 8rpx;
}
.conv-name {
  flex: 1;
  font-size: var(--fs-subtitle);
  color: var(--text-primary);
  font-weight: 600;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.conv-time {
  flex: 0 0 auto;
  font-size: var(--fs-feed-meta);
  color: var(--text-secondary);
}
.conv-preview {
  flex: 1;
  font-size: var(--fs-body);
  color: var(--text-secondary);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.conv-badge {
  flex: 0 0 auto;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: var(--radius-pill);
  background: var(--danger-text);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 36rpx;
  text-align: center;
}

/* 空态 / 加载 */
.msgs-state {
  padding: 120rpx var(--pad-shell);
  text-align: center;
  color: var(--text-secondary);
}
.state-emoji {
  font-size: 80rpx;
  margin-bottom: 18rpx;
}
.state-title {
  font-size: var(--fs-feed-title);
  color: var(--text-primary);
  font-weight: 700;
}
.state-copy {
  margin: 12rpx 0 28rpx;
  font-size: var(--fs-body);
  color: var(--text-secondary);
}
.state-btn {
  display: inline-block;
  padding: 16rpx 44rpx;
  background: var(--accent-blue);
  color: #ffffff;
  font-size: var(--fs-btn);
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-btn-primary);
}

/* 登录闸 */
.gate {
  padding: 160rpx var(--pad-shell);
  text-align: center;
}
.gate-title {
  font-size: var(--fs-feed-title);
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 36rpx;
}
.gate-btn {
  display: inline-block;
  padding: 18rpx 56rpx;
  background: var(--accent-blue);
  color: #ffffff;
  font-size: var(--fs-btn);
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-btn-primary);
}
