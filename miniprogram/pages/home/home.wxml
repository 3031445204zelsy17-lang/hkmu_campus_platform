<app-header bind:languagechange="handleLanguageChange" />

<view class="page-shell feed-shell">
  <view class="top-bar">
    <view class="brand-lockup">
      <view class="eyebrow">{{text.brand}}</view>
      <view class="app-title">{{text.title}}</view>
    </view>
  </view>

  <view class="compose-card" bindtap="goCompose">
    <view class="compose-row">
      <view class="avatar small">
        <image wx:if="{{user && user.avatar_url}}" src="{{user.avatar_url}}" mode="aspectFill" />
        <view wx:else>{{userInitial}}</view>
      </view>
      <view class="compose-placeholder">{{text.composePlaceholder}}</view>
      <view class="compose-submit">{{text.publish}}</view>
    </view>
  </view>

  <view class="search-dock">
    <view class="search-mark">#</view>
    <input
      class="search-input"
      placeholder="{{text.searchPlaceholder}}"
      value="{{keyword}}"
      confirm-type="search"
      bindinput="updateKeyword"
      bindconfirm="submitSearch"
    />
    <view wx:if="{{keyword}}" class="text-link" bindtap="clearSearch">{{text.clear}}</view>
  </view>

  <view class="segmented">
    <view
      wx:for="{{feedTabs}}"
      wx:key="key"
      class="{{item.className}}"
      data-sort="{{item.key}}"
      bindtap="switchSort"
    >
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{posts.length === 0 && !loading}}" class="empty-state">
    <view class="empty-icon">{{text.emptyIcon}}</view>
    <view class="empty-title">{{text.emptyTitle}}</view>
    <view class="empty-copy">{{text.emptyCopy}}</view>
    <button class="primary-action empty-action" bindtap="goCompose">{{text.emptyAction}}</button>
  </view>

  <view class="feed-list">
    <view wx:for="{{posts}}" wx:key="id" class="feed-card">
      <view class="feed-head">
        <view class="avatar" data-author-id="{{item.authorId}}" catchtap="openDM">
          <image wx:if="{{item.authorAvatar}}" src="{{item.authorAvatar}}" mode="aspectFill" />
          <view wx:else>{{item.authorInitial}}</view>
        </view>
        <view class="feed-main">
          <view class="feed-author-row">
            <view>
              <view class="feed-author">{{item.authorName}}</view>
              <view class="feed-meta">{{item.handle}} {{text.feedMetaSeparator}} {{item.createdAtLabel}}</view>
            </view>
            <view class="{{item.topicClass}}">{{item.category}}</view>
          </view>
          <view class="feed-title">{{item.title}}</view>
          <image wx:if="{{item.imageUrl}}" class="feed-image" src="{{item.imageUrl}}" mode="widthFix" />
          <view class="feed-body">{{item.content}}</view>
          <view class="post-actions">
            <view class="{{item.likeClass}}" data-index="{{index}}" catchtap="toggleLike" hover-class="post-action-press">
              <text class="{{item.likeIconClass}}">{{item.likeIcon}}</text>
              <text class="post-action-count">{{item.likeLabel}}</text>
            </view>
            <view class="post-action comment-action" catchtap="openComments" hover-class="post-action-press">
              <view class="post-comment-icon">
                <view class="post-comment-bubble"></view>
                <view class="post-comment-tail"></view>
              </view>
              <text class="post-action-count">{{item.commentsLabel}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="web-panel">
    <view class="section-title">{{text.quickTitle}}</view>
    <view class="quick-entry" bindtap="goCommunity">
      <view class="quick-icon">○</view>
      <view>
        <view class="quick-title">{{text.quickItems.communityTitle}}</view>
        <view class="quick-copy">{{text.quickItems.communityCopy}}</view>
      </view>
    </view>
    <view class="quick-entry" bindtap="goNews">
      <view class="quick-icon">▤</view>
      <view>
        <view class="quick-title">{{text.quickItems.newsTitle}}</view>
        <view class="quick-copy">{{text.quickItems.newsCopy}}</view>
      </view>
    </view>
    <view class="quick-entry" bindtap="goLostFound">
      <view class="quick-icon">⌕</view>
      <view>
        <view class="quick-title">{{text.quickItems.lostTitle}}</view>
        <view class="quick-copy">{{text.quickItems.lostCopy}}</view>
      </view>
    </view>
    <view class="quick-entry" bindtap="goPlanner">
      <view class="quick-icon">□</view>
      <view>
        <view class="quick-title">{{text.quickItems.plannerTitle}}</view>
        <view class="quick-copy">{{text.quickItems.plannerCopy}}</view>
      </view>
    </view>
  </view>

  <view class="web-panel">
    <view class="section-title">{{text.statusTitle}}</view>
    <view class="panel-copy">{{text.statusCopy}}</view>
    <button class="web-primary-btn refresh-btn" bindtap="submitSearch">{{text.refreshAction}}</button>
  </view>

  <view wx:if="{{loading}}" class="loading-line">{{text.loading}}</view>
</view>
