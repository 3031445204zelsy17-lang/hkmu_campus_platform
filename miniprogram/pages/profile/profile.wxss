/* Profile edit mode — page-level styles only, all via tokens.wxss var().
   View-mode styling lives in app.wxss (profile-card / avatar / action-row …). */

.avatar-edit-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 0;
}

/* inline-block so the wrap shrink-wraps the 128rpx avatar; otherwise the
   absolutely-positioned badge would anchor to the full card width. */
.avatar-edit-wrap {
  position: relative;
  display: inline-block;
}

.avatar-edit-badge {
  position: absolute;
  right: -6rpx;
  bottom: -6rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-pill);
  background: var(--accent-blue);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 1;
  box-shadow: var(--shadow-btn-primary);
}

.avatar-hint {
  margin-top: 16rpx;
  color: var(--text-secondary);
  font-size: var(--fs-link);
}

/* Phase 5: HKMU 已验证徽章(视图模式,name 旁)— 页面级,不动 app.wxss */
.verified-badge {
  display: inline-block;
  margin-left: 12rpx;
  padding: 2rpx 14rpx;
  border-radius: var(--radius-pill);
  background: var(--accent-blue);
  color: #ffffff;
  font-size: var(--fs-link);
  vertical-align: middle;
}
