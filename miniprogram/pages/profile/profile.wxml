<app-header bind:languagechange="handleLanguageChange" />

<view class="page-shell">
  <view class="profile-cover"></view>

  <view wx:if="{{user}}">
    <!-- 视图模式 -->
    <view wx:if="{{!editing}}" class="profile-card">
      <view class="avatar large">
        <image wx:if="{{user.avatar_url}}" src="{{user.avatar_url}}" mode="aspectFill" />
        <view wx:else>{{user.initial}}</view>
      </view>
      <view class="profile-name">
        {{user.displayName}}
        <view wx:if="{{user.hkmu_verified}}" class="verified-badge">{{text.hkmuVerifiedBadge}}</view>
      </view>
      <view class="profile-handle">@{{user.username}} {{text.separator}} {{identityLabel}}</view>
      <view class="profile-bio">{{user.bioLabel}}</view>

      <view class="profile-stats">
        <view class="profile-stat">
          <view class="profile-stat-value">{{joinedAtDisplay}}</view>
          <view class="profile-stat-label">{{text.joinedLabel}}</view>
        </view>
        <view class="profile-stat">
          <view class="profile-stat-value">{{user.providerLabel}}</view>
          <view class="profile-stat-label">{{text.providerLabel}}</view>
        </view>
      </view>

      <view class="action-row">
        <button class="primary-action" bindtap="goCompose">{{text.composeAction}}</button>
        <button class="secondary-action" bindtap="enterEdit">{{text.editAction}}</button>
      </view>

      <!-- Phase 5: 社交冷启动(同校验证 + 邀请好友)-->
      <view class="action-row">
        <button wx:if="{{!user.hkmu_verified}}" class="secondary-action" bindtap="startBindEmail">{{text.bindEmailAction}}</button>
        <button class="secondary-action" open-type="share">{{text.inviteAction}}</button>
      </view>

      <view class="profile-list">
        <view class="profile-row">
          <view class="profile-row-label">{{text.emailLabel}}</view>
          <view class="profile-row-value">{{user.emailLabel}}</view>
        </view>
        <view class="profile-row">
          <view class="profile-row-label">{{text.studentIdLabel}}</view>
          <view class="profile-row-value">{{user.studentIdLabel}}</view>
        </view>
        <view class="profile-row">
          <view class="profile-row-label">{{text.bioLabel}}</view>
          <view class="profile-row-value">{{user.bioLabel}}</view>
        </view>
        <view class="profile-row" bindtap="openPrivacy">
          <view class="profile-row-label">{{privacyAction}}</view>
          <view class="profile-row-value">›</view>
        </view>
        <view class="profile-row" bindtap="openFeedback">
          <view class="profile-row-label">{{feedbackAction}}</view>
          <view class="profile-row-value">›</view>
        </view>
      </view>

      <view class="action-row">
        <button class="danger-action" bindtap="logout">{{text.logoutAction}}</button>
      </view>
    </view>

    <!-- 编辑模式 -->
    <view wx:else class="profile-card">
      <view class="avatar-edit-block">
        <view class="avatar-edit-wrap" bindtap="chooseAvatar">
          <view class="avatar large">
            <image wx:if="{{draftAvatarUrl}}" src="{{draftAvatarUrl}}" mode="aspectFill" />
            <view wx:else>{{user.initial}}</view>
          </view>
          <view class="avatar-edit-badge">+</view>
        </view>
        <view class="avatar-hint">{{text.avatarChangeHint}}</view>
      </view>

      <view class="field-label">{{text.nicknameLabel}}</view>
      <input
        class="text-input"
        maxlength="40"
        placeholder="{{text.nicknamePlaceholder}}"
        value="{{draftNickname}}"
        data-field="draftNickname"
        bindinput="updateDraft"
      />

      <view class="field-label">{{text.bioLabel}}</view>
      <textarea
        class="text-area"
        maxlength="200"
        placeholder="{{text.bioPlaceholder}}"
        value="{{draftBio}}"
        data-field="draftBio"
        bindinput="updateDraft"
      />

      <view class="action-row">
        <button class="primary-action" loading="{{saving}}" bindtap="saveProfile">{{text.saveAction}}</button>
        <button class="secondary-action" bindtap="cancelEdit">{{text.cancelAction}}</button>
      </view>
    </view>
  </view>

  <view wx:else>
    <view class="top-bar tight">
      <view class="brand-lockup">
        <view class="eyebrow">{{text.eyebrow}}</view>
        <view class="app-title">{{text.title}}</view>
        <view class="subtitle">{{text.subtitle}}</view>
      </view>
    </view>
    <view class="empty-state flat">
      <view class="empty-title">{{text.emptyTitle}}</view>
      <view class="empty-copy">{{text.emptyCopy}}</view>
      <view class="action-row">
        <button class="primary-action" bindtap="goToLogin">{{text.loginAction}}</button>
      </view>
    </view>
  </view>
</view>
