.feedback-page {
  min-height: 100vh;
  background: #F7FAF6;
  padding: 24rpx;
  box-sizing: border-box;
}

.feedback-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.feedback-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.feedback-hint {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 36rpx;
}

.field-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 16rpx;
}

.rating-row {
  display: flex;
  gap: 18rpx;
  margin-bottom: 36rpx;
}

.rating-star {
  font-size: 60rpx;
  color: #d1d5db;
  line-height: 1;
}

.rating-star.active {
  color: #f5a623;
}

.feedback-textarea {
  width: 100%;
  box-sizing: border-box;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  min-height: 220rpx;
  margin-bottom: 28rpx;
}

.feedback-input {
  width: 100%;
  box-sizing: border-box;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 36rpx;
}

.contact-hint {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: -20rpx;
  margin-bottom: 28rpx;
}

.feedback-submit {
  width: 100%;
  background: #3D7A2E;
  color: #ffffff;
  border-radius: 14rpx;
  padding: 26rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.feedback-submit[disabled] {
  background: #9ca3af;
}
