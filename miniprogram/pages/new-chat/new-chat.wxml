<app-header show-back="{{true}}" title="{{text.headerTitle}}" bind:languagechange="handleLanguageChange" />

<view class="nc">
  <view class="nc-searchbar">
    <input
      class="nc-search"
      value="{{kw}}"
      placeholder="{{text.searchPlaceholder}}"
      placeholder-class="nc-ph"
      confirm-type="search"
      focus
      bindinput="onInput"
    />
  </view>

  <!-- 搜索中 -->
  <view wx:if="{{loading}}" class="nc-hint">{{text.loading}}</view>
  <!-- 已搜索,无结果 -->
  <view wx:elif="{{searched && results.length === 0}}" class="nc-hint">{{text.noResults}}</view>
  <!-- 已搜索,结果列表 -->
  <view wx:elif="{{searched}}" class="nc-list">
    <view wx:for="{{results}}" wx:key="id">
      <template is="ncUserCard" data="{{...item}}" />
    </view>
  </view>
  <!-- 未搜索且已登录:发现区(我的好友 + 可能认识的同学) -->
  <block wx:elif="{{loggedIn}}">
    <view class="nc-section">
      <view class="nc-section-title">{{text.friendsTitle}}</view>
      <view wx:if="{{!friendsLoaded}}" class="nc-section-hint">{{text.loadingHint}}</view>
      <view wx:elif="{{friends.length === 0}}" class="nc-section-hint">{{text.friendsEmpty}}</view>
      <view wx:else class="nc-section-list">
        <view wx:for="{{friends}}" wx:key="id">
          <template is="ncUserCard" data="{{...item}}" />
        </view>
      </view>
    </view>

    <view class="nc-section">
      <view class="nc-section-title">{{text.suggestTitle}}</view>
      <view wx:if="{{!suggestLoaded}}" class="nc-section-hint">{{text.loadingHint}}</view>
      <view wx:elif="{{suggest.length === 0}}" class="nc-section-hint">{{text.suggestEmpty}}</view>
      <view wx:else class="nc-section-list">
        <view wx:for="{{suggest}}" wx:key="id">
          <template is="ncUserCard" data="{{...item}}" />
        </view>
      </view>
    </view>
  </block>
  <!-- 未登录兜底 -->
  <view wx:else class="nc-hint">{{text.hint}}</view>
</view>

<!-- 用户卡片:results / friends / suggest 共用;suggest 项带 reason 标签 -->
<template name="ncUserCard">
  <view class="nc-user" data-id="{{id}}" data-name="{{name}}" data-avatar="{{avatar}}" bindtap="openUser">
    <view class="nc-avatar">
      <image wx:if="{{avatar}}" src="{{avatar}}" mode="aspectFill" class="nc-avatar-img" />
      <view wx:else class="nc-avatar-fallback">{{initial}}</view>
    </view>
    <view class="nc-info">
      <text class="nc-name">{{name}}</text>
      <text wx:if="{{handle}}" class="nc-handle">{{handle}}</text>
    </view>
    <view wx:if="{{reason}}" class="nc-reason">{{reason}}</view>
  </view>
</template>
