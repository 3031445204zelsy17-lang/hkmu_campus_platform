/* pages/community/community.wxss */

.community-board-scroll {
  width: 100%;
  margin: 0 0 22rpx;
  white-space: nowrap;
}

.community-board-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 44rpx 8rpx;
  box-sizing: border-box;
}

.community-board-item {
  width: 150rpx;
  min-height: 116rpx;
  padding: 16rpx 12rpx;
  border: 1rpx solid rgba(90, 130, 90, 0.12);
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 34rpx rgba(30, 70, 40, 0.05);
  color: #6B7280;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  text-align: center;
  vertical-align: top;
}

.community-board-item.active {
  border-color: rgba(127, 191, 77, 0.28);
  background: #F4FAF1;
  box-shadow:
    0 14rpx 38rpx rgba(30, 70, 40, 0.07),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
  color: #3D7A2E;
}

.community-board-icon {
  min-width: 48rpx;
  height: 48rpx;
  padding: 0 10rpx;
  border-radius: 16rpx;
  border: 1rpx solid currentColor;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1;
}

.community-board-label {
  max-width: 100%;
  margin-top: 10rpx;
  font-size: 23rpx;
  font-weight: 650;
  line-height: 1.15;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* === Comments (Phase 1 ③) — page-scoped, token-only === */
.comment-section {
  margin: 20rpx 0 0;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-entry);
  background: var(--segmented-bg);
  border: 1rpx solid var(--border-hair);
}

.comment-status {
  padding: 18rpx 0;
  font-size: var(--fs-feed-meta);
  color: var(--text-secondary);
  text-align: center;
}

.comment-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--divider);
}
.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--hero-gradient);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.comment-main {
  flex: 1;
  min-width: 0;
}
.comment-author {
  font-size: var(--fs-feed-meta);
  font-weight: 650;
  color: var(--text-primary);
}
.comment-content {
  margin-top: 4rpx;
  font-size: var(--fs-feed-body);
  line-height: 1.45;
  color: var(--text-primary);
  word-break: break-word;
}
.comment-meta {
  margin-top: 6rpx;
  font-size: var(--fs-link);
  color: var(--text-secondary);
}

.comment-composer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--divider);
}
.comment-input {
  flex: 1;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-pill);
  background: var(--surface);
  border: 1rpx solid var(--border-soft);
  font-size: var(--fs-feed-meta);
  color: var(--text-primary);
}
.comment-send {
  flex-shrink: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-pill);
  background: var(--accent-blue);
  color: #FFFFFF;
  font-size: var(--fs-btn);
  font-weight: 650;
}
.comment-send.is-busy {
  opacity: var(--press-opacity);
}
