/* pages/planner/planner.wxss
   页面级样式，全部走 styles/tokens.wxss 的 var()。
   复用 app.wxss 的 web-panel / section-title / panel-copy / course-row /
   course-code / course-name / mini-pill / planner-hero / planner-score 等。
   分类配色（cat-*）为与 web planner 对齐的 6 色，作为页面局部 var 定义在此，
   不动共享 tokens.wxss；将来若全局复用可迁回。 */

.planner-shell {
  --cat-blue: #3B82F6;
  --cat-purple: #8B5CF6;
  --cat-amber: #F59E0B;
  --cat-emerald: #10B981;
  --cat-pink: #EC4899;
  --cat-indigo: #6366F1;
}

/* 专业选择器 */
.selector-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: var(--segmented-bg);
  border-radius: var(--radius-entry);
}

.selector-text {
  color: var(--text-primary);
  font-size: var(--fs-body);
  font-weight: 600;
}

.selector-caret {
  color: var(--text-secondary);
  font-size: var(--fs-body);
}

/* 总进度 */
.credits-summary {
  color: var(--text-primary);
  font-size: var(--fs-feed-body);
  font-weight: 600;
  margin: 8rpx 0 20rpx;
}

.progress-track {
  width: 100%;
  height: 14rpx;
  border-radius: var(--radius-pill);
  background: var(--border-soft);
  overflow: hidden;
}

.progress-track-lg {
  height: 20rpx;
}

.progress-fill {
  height: 100%;
  border-radius: var(--radius-pill);
  background: var(--accent-blue);
  transition: width 0.3s ease;
}

/* 分类行 */
.category-row {
  padding: 20rpx 0;
}

.category-row + .category-row {
  border-top: 1rpx solid var(--divider);
}

.category-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.category-name {
  color: var(--text-primary);
  font-size: var(--fs-body);
  font-weight: 600;
}

.category-credits {
  color: var(--text-secondary);
  font-size: var(--fs-link);
}

/* 分类配色 */
.cat-blue { background: var(--cat-blue); }
.cat-purple { background: var(--cat-purple); }
.cat-amber { background: var(--cat-amber); }
.cat-emerald { background: var(--cat-emerald); }
.cat-pink { background: var(--cat-pink); }
.cat-indigo { background: var(--cat-indigo); }

/* 未登录卡 */
.planner-login .planner-subtitle {
  margin-top: 32rpx;
}

.planner-cta {
  display: inline-block;
  margin-top: 24rpx;
  padding: 18rpx 40rpx;
  background: var(--accent-blue);
  color: #ffffff;
  font-size: var(--fs-btn);
  font-weight: 600;
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-btn-primary);
}

/* 推荐卡片课程主区 */
.course-main {
  display: flex;
  flex-direction: column;
}

/* segmented 总览/我的课程 */
.seg-bar {
  display: flex;
  gap: 8rpx;
  margin: 16rpx 0 24rpx;
  background: var(--segmented-bg);
  border-radius: var(--radius-pill);
  padding: 6rpx;
}
.seg-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: var(--radius-pill);
  color: var(--text-secondary);
  font-size: var(--fs-link);
  font-weight: 600;
}
.seg-on {
  background: var(--surface, #ffffff);
  color: var(--text-primary);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

/* 搜索框 */
.planner-search {
  padding: 8rpx 0;
}
.search-input {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
  background: var(--segmented-bg);
  border-radius: var(--radius-entry);
  font-size: var(--fs-body);
  color: var(--text-primary);
}

/* 学期分组头 */
.sem-header {
  margin: 24rpx 4rpx 12rpx;
  color: var(--text-secondary);
  font-size: var(--fs-link);
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 课程卡点击反馈 */
.course-tap {
  transition: background 0.15s;
}
.course-tap:active {
  background: var(--segmented-bg);
}

/* 先修提示 */
.prereq-row {
  margin-top: 6rpx;
  font-size: 22rpx;
}
.prereq-row.met {
  color: var(--cat-emerald);
}
.prereq-row.unmet {
  color: var(--text-secondary);
}

/* 状态 pill:进行中 amber(已完成 green 已在 app.wxss) */
.mini-pill.amber {
  background: var(--cat-amber);
  color: #ffffff;
}

/* 课程目录（非完整规划专业） */
.catalogue-disclaimer {
  margin: 0 0 24rpx;
  padding: 20rpx 24rpx;
  background: var(--segmented-bg);
  border-left: 6rpx solid var(--cat-amber);
  border-radius: var(--radius-entry);
  font-size: var(--fs-link);
  color: var(--text-primary);
  line-height: 1.5;
}
.catalogue-stats {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
}
.cat-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.cat-stat-num {
  font-size: var(--fs-title);
  font-weight: 700;
  color: var(--text-primary);
}
.cat-stat-label {
  margin-top: 4rpx;
  font-size: var(--fs-link);
  color: var(--text-secondary);
}
.mini-pill.gray {
  background: var(--segmented-bg);
  color: var(--text-secondary);
}
.catalogue-showall {
  margin-top: 16rpx;
  padding: 12rpx 0;
  font-size: var(--fs-link);
  color: var(--accent-blue);
  text-align: left;
}

/* 专业搜索选择器（替代滚轮 picker） */
.programme-search-input {
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx 24rpx;
  background: var(--surface);
  border: 1rpx solid var(--divider);
  border-radius: var(--radius-entry);
  font-size: var(--fs-body);
  color: var(--text-primary);
}
.programme-search-results {
  height: 520rpx;
  margin-top: 16rpx;
  border: 1rpx solid var(--divider);
  border-radius: var(--radius-entry);
  background: var(--surface);
}
.programme-search-group {
  position: sticky;
  top: 0;
  padding: 12rpx 24rpx;
  background: var(--segmented-bg);
  color: var(--text-secondary);
  font-size: var(--fs-link);
  font-weight: 600;
}
.programme-search-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 24rpx;
  border-top: 1rpx solid var(--divider);
}
.programme-search-row.ps-selected {
  background: var(--segmented-bg);
}
.ps-name {
  flex: 1;
  color: var(--text-primary);
  font-size: var(--fs-feed-body);
}
.ps-code {
  flex-shrink: 0;
  color: var(--text-secondary);
  font-size: var(--fs-link);
}
.programme-search-empty {
  padding: 36rpx;
  text-align: center;
  color: var(--text-secondary);
  font-size: var(--fs-link);
}
