<app-header bind:languagechange="handleLanguageChange" />

<view class="page-shell planner-shell">
  <view class="top-bar tight">
    <view class="brand-lockup">
      <view class="eyebrow">{{text.eyebrow}}</view>
      <view class="app-title">{{text.title}}</view>
      <view class="subtitle">{{text.subtitle}}</view>
    </view>
  </view>

  <!-- 专业选择 -->
  <view class="web-panel planner-selector">
    <view class="field-label">{{text.selectProgramme}}</view>
    <picker
      mode="selector"
      range="{{programmeOptions}}"
      range-key="label"
      value="{{programmeIndex}}"
      bindchange="onProgrammeChange"
    >
      <view class="selector-display">
        <text class="selector-text">{{programmeOptions[programmeIndex].label}}</text>
        <text class="selector-caret">▾</text>
      </view>
    </picker>
  </view>

  <!-- Hero：专业名 + 总进度 -->
  <view class="planner-hero">
    <view>
      <view class="planner-kicker">{{programmeSchool}}</view>
      <view class="planner-title">{{programmeName}}</view>
      <view class="planner-copy">
        <block wx:if="{{viewMode==='catalogue'}}">{{text.catalogueHeroCopy}}</block>
        <block wx:elif="{{loggedIn && !comingSoon}}">{{creditsSummary}}</block>
        <block wx:elif="{{comingSoon}}">{{text.comingSoonCopy}}</block>
        <block wx:else>{{text.heroCopy}}</block>
      </view>
    </view>
    <view wx:if="{{loggedIn && !comingSoon && viewMode==='planning'}}" class="planner-score">{{percent}}%</view>
  </view>

  <!-- 总览/我的课程 切换 -->
  <view wx:if="{{showTabs}}" class="seg-bar">
    <view class="seg-item {{activeTab==='overview'?'seg-on':''}}" data-tab="overview" bindtap="onTabChange">{{text.tabOverview}}</view>
    <view class="seg-item {{activeTab==='courses'?'seg-on':''}}" data-tab="courses" bindtap="onTabChange">{{text.tabCourses}}</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="web-panel">
    <view class="panel-copy">{{text.loading}}</view>
  </view>

  <!-- 课程目录（非完整规划专业：全校 ~106 专业官方课程列表） -->
  <view wx:elif="{{viewMode==='catalogue'}}" class="planner-catalogue">
    <view class="catalogue-disclaimer">{{catalogueDisclaimer}}</view>

    <view wx:if="{{catalogueLoading}}" class="web-panel">
      <view class="panel-copy">{{text.loading}}</view>
    </view>

    <view wx:elif="{{catalogueLoadError}}" class="web-panel">
      <view class="panel-copy">{{catalogueLoadError}}</view>
    </view>

    <block wx:else>
      <view class="web-panel catalogue-stats">
        <view class="cat-stat">
          <text class="cat-stat-num">{{catalogueTotal}}</text>
          <text class="cat-stat-label">{{text.totalCourses}}</text>
        </view>
        <view class="cat-stat">
          <text class="cat-stat-num">{{catalogueBuckets.length}}</text>
          <text class="cat-stat-label">{{text.catalogueGroupCount}}</text>
        </view>
      </view>

      <view wx:for="{{catalogueBuckets}}" wx:for-item="b" wx:key="key" class="web-panel">
        <view class="section-title">{{b.label}} ({{b.total}})</view>
        <view wx:for="{{b.courses}}" wx:for-item="c" wx:key="code" class="course-row catalogue-row">
          <view class="course-main">
            <view class="course-code">{{c.code}}</view>
            <view class="course-name">{{c.name}} · {{c.credits}}cr</view>
          </view>
          <view class="mini-pill gray">{{c.system}}</view>
        </view>
        <view wx:if="{{b.collapsed}}" class="catalogue-showall" data-bucket="{{b.key}}" bindtap="onToggleBucket">{{b.showAllLabel}}</view>
      </view>
    </block>
  </view>

  <!-- 敬请期待（占位专业） -->
  <view wx:elif="{{comingSoon}}" class="web-panel">
    <view class="section-title">{{text.comingSoonTitle}}</view>
    <view class="panel-copy">{{text.comingSoonCopy}}</view>
  </view>

  <!-- 未登录 -->
  <view wx:elif="{{!loggedIn}}" class="web-panel planner-login">
    <view class="section-title">{{text.loginPromptTitle}}</view>
    <view class="panel-copy">{{text.loginPromptCopy}}</view>
    <view class="planner-cta" bindtap="goLogin">{{text.loginAction}}</view>

    <view wx:if="{{categoriesView.length}}" class="section-title planner-subtitle">{{text.categoriesTitle}}</view>
    <view
      wx:for="{{categoriesView}}"
      wx:key="key"
      class="category-row"
    >
      <view class="category-head">
        <text class="category-name">{{item.label}}</text>
        <text class="category-credits">{{text.requiredCredits}}{{item.required}} cr</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: 0%"></view>
      </view>
    </view>
  </view>

  <!-- 已登录：毕业仪表盘 -->
  <block wx:elif="{{activeTab==='overview'}}">
    <view class="web-panel">
      <view class="section-title">{{text.progressTitle}}</view>
      <view class="credits-summary">{{creditsSummary}}</view>
      <view class="progress-track progress-track-lg">
        <view class="progress-fill" style="width: {{percent}}%"></view>
      </view>
    </view>

    <view class="web-panel">
      <view class="section-title">{{text.categoriesTitle}}</view>
      <view
        wx:for="{{categoriesView}}"
        wx:key="key"
        class="category-row"
      >
        <view class="category-head">
          <text class="category-name">{{item.label}}</text>
          <text class="category-credits">{{item.earned}}/{{item.required}} cr</text>
        </view>
        <view class="progress-track">
          <view class="progress-fill cat-{{item.color}}" style="width: {{item.pct}}%"></view>
        </view>
      </view>
    </view>

    <view wx:if="{{recommendations.length}}" class="web-panel">
      <view class="section-title">{{text.recommendTitle}}</view>
      <view
        wx:for="{{recommendations}}"
        wx:key="course_id"
        class="course-row"
      >
        <view class="course-main">
          <view class="course-code">{{item.code}}</view>
          <view class="course-name">{{item.name}} · {{item.credits}}cr</view>
        </view>
        <view class="mini-pill green">{{item.categoryLabel}}</view>
      </view>
    </view>
  </block>

  <!-- 我的课程:按学年学期分组 + 搜索 + 标记 -->
  <block wx:elif="{{activeTab==='courses'}}">
    <view class="web-panel planner-search">
      <input class="search-input" value="{{searchKeyword}}"
             placeholder="{{text.searchPlaceholder}}" bindinput="onSearchInput" />
    </view>

    <block wx:for="{{coursesView.semesters}}" wx:for-item="sem" wx:key="label">
      <view class="sem-header">{{sem.label}}</view>
      <view wx:for="{{sem.courses}}" wx:for-item="c" wx:key="courseId"
            class="course-row course-tap"
            data-course-id="{{c.courseId}}" data-code="{{c.code}}"
            bindtap="openCourseDetail">
        <view class="course-main">
          <view class="course-code">{{c.code}}</view>
          <view class="course-name">{{c.name}} · {{c.credits}}cr</view>
          <view wx:if="{{c.prereqLabel}}" class="prereq-row {{c.prereqsMet?'met':'unmet'}}">{{c.prereqLabel}}</view>
        </view>
        <view wx:if="{{c.statusKey==='completed'}}" class="mini-pill green">{{c.statusLabel}}</view>
        <view wx:elif="{{c.statusKey==='in_progress'}}" class="mini-pill amber">{{c.statusLabel}}</view>
      </view>
    </block>

    <view wx:if="{{coursesView.empty}}" class="web-panel">
      <view class="panel-copy">{{text.coursesEmpty}}</view>
    </view>
  </block>
</view>
