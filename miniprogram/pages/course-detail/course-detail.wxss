/* pages/course-detail/course-detail.wxss — page-scoped, token-only.
   复用 app.wxss 全局 class:web-panel / section-title / mini-pill / course-code
   / course-name / loading-line / empty-state / empty-title / empty-copy。
   comment-* / review-* / status-seg / star-picker / login-prompt 为本页自带
   (视觉与 post-detail 课评区一致)。--star-fill 为页面局部 var(照 planner --cat-* 先例)。 */

.detail-shell {
  --star-fill: #F59E0B; /* 课评星色,页面局部,不进共享 tokens */
  padding-bottom: var(--shell-bottom);
}

/* === 课程 hero 卡 === */
.course-hero {
  margin-top: 0;
}
.course-hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.course-hero-name {
  margin-top: 12rpx;
  color: var(--text-primary);
  font-size: var(--fs-feed-title);
  font-weight: 700;
  line-height: 1.3;
}
.course-hero-meta {
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: var(--fs-feed-meta);
}
.course-desc {
  margin-top: 20rpx;
  color: var(--text-primary);
  font-size: var(--fs-feed-body);
  line-height: 1.6;
  word-break: break-word;
}
.course-prereqs {
  margin-top: 18rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-entry);
  background: var(--segmented-bg);
  font-size: var(--fs-link);
}
.course-prereq-label {
  color: var(--text-secondary);
  margin-right: 8rpx;
}
.course-prereq-text {
  color: var(--text-primary);
}
.course-official-note {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--divider);
  color: var(--text-secondary);
  font-size: var(--fs-link);
  line-height: 1.5;
}

/* === 内联标记 segmented(3 态) === */
.status-seg {
  display: flex;
  gap: 8rpx;
  margin-top: 18rpx;
  padding: 6rpx;
  background: var(--segmented-bg);
  border-radius: var(--radius-pill);
}
.status-seg-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: var(--radius-pill);
  color: var(--text-secondary);
  font-size: var(--fs-link);
  font-weight: 600;
}
.status-seg-on {
  background: var(--surface, #ffffff);
  color: var(--text-primary);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.login-prompt {
  margin: 0 0 24rpx;
  padding: 24rpx;
  border-radius: var(--radius-entry);
  background: var(--segmented-bg);
  border: 1rpx dashed var(--border-soft);
  font-size: var(--fs-feed-meta);
  color: var(--accent-blue);
  text-align: center;
}

/* === 课评分 + 列表(视觉对齐 post-detail 评论区) === */
.reviews-section {
  /* web-panel 已给卡片底色与阴影 */
}
.reviews-header {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid var(--divider);
}
.reviews-count {
  color: var(--text-secondary);
  font-size: var(--fs-feed-meta);
}
.rating-summary {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 0 8rpx;
}
.rating-avg {
  color: var(--text-primary);
  font-size: var(--fs-section);
  font-weight: 700;
}
.rating-stars {
  color: var(--star-fill);
  font-size: var(--fs-feed-meta);
  letter-spacing: 2rpx;
}
.rating-count {
  color: var(--text-secondary);
  font-size: var(--fs-link);
}

.review-status {
  padding: 28rpx 0;
  font-size: var(--fs-feed-meta);
  color: var(--text-secondary);
  text-align: center;
}

.review-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--divider);
}
.review-item:last-of-type {
  border-bottom: none;
}
.review-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.comment-avatar {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--hero-gradient);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.review-head-main {
  flex: 1;
  min-width: 0;
}
.comment-author {
  font-size: var(--fs-feed-meta);
  font-weight: 650;
  color: var(--text-primary);
}
.review-stars {
  margin-top: 4rpx;
  color: var(--star-fill);
  font-size: var(--fs-link);
  letter-spacing: 2rpx;
}
.review-delete {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-pill);
  background: var(--danger-bg);
  color: var(--danger-text);
  font-size: var(--fs-link);
  font-weight: 600;
}
.review-content {
  margin-top: 10rpx;
  font-size: var(--fs-feed-body);
  line-height: 1.5;
  color: var(--text-primary);
  word-break: break-word;
}
.comment-meta {
  margin-top: 8rpx;
  font-size: var(--fs-link);
  color: var(--text-secondary);
}

/* === 课评 composer === */
.review-composer {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.star-hint {
  color: var(--text-secondary);
  font-size: var(--fs-link);
}
.star-picker {
  display: flex;
  gap: 14rpx;
}
.star {
  color: var(--border-soft);
  font-size: 52rpx;
  line-height: 1;
}
.star-on {
  color: var(--star-fill);
}
.review-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 120rpx;
  max-height: 320rpx;
  padding: 18rpx 22rpx;
  border-radius: var(--radius-entry);
  background: var(--segmented-bg);
  font-size: var(--fs-feed-meta);
  color: var(--text-primary);
}
.comment-send {
  align-self: flex-end;
  min-width: 96rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-pill);
  background: var(--accent-blue);
  color: #ffffff;
  font-size: var(--fs-btn);
  font-weight: 650;
  text-align: center;
  box-shadow: var(--shadow-btn-primary);
}
.comment-send.is-busy {
  opacity: var(--press-opacity);
}
.review-done-hint {
  margin: 0 0 24rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-entry);
  background: var(--segmented-bg);
  color: var(--text-secondary);
  font-size: var(--fs-feed-meta);
  text-align: center;
}
