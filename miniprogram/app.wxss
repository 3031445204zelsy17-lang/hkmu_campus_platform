.web-secondary-btn {
  min-height: 68rpx;
  border: 1rpx solid #E5EFE3;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #3D7A2E;
  box-shadow: 0 8rpx 22rpx rgba(30, 70, 40, 0.04);
  line-height: 68rpx;
}

.danger-action {
  min-height: 68rpx;
  border: 1rpx solid rgba(180, 60, 60, 0.12);
  border-radius: 999rpx;
  background: #FFF7F7;
  color: #B42318;
  box-shadow: none;
  line-height: 68rpx;
}

.search-dock {
  min-height: 84rpx;
  margin: 0 44rpx 22rpx;
  padding: 0 24rpx;
  border-radius: 40rpx;
  color: #3D7A2E;
}

.search-dock.flat {
  margin-left: 0;
  margin-right: 0;
}

.search-mark {
  color: #7FBF4D;
  font-size: 28rpx;
  font-weight: 700;
}

.search-input {
  height: 82rpx;
  color: #142033;
  font-size: 28rpx;
}

.text-link {
  color: #0F8FBE;
  font-size: 24rpx;
  font-weight: 600;
}

.segmented {
  margin: 0 44rpx 28rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #EEF5EC;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.segmented.flat {
  margin-left: 0;
  margin-right: 0;
}

.segment-item {
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6B7280;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
  transition:
    color 180ms ease,
    background 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.segment-item.active,
.category-chip.active {
  background: #FFFFFF;
  color: #3D7A2E;
  box-shadow: 0 8rpx 22rpx rgba(30, 70, 40, 0.08);
}

.feed-list {
  padding: 0 44rpx;
  border-top: 0;
}

.feed-card {
  margin-bottom: 28rpx;
  padding: 40rpx;
  border-radius: 44rpx;
}

.feed-head {
  gap: 24rpx;
}

.feed-author-row {
  align-items: flex-start;
  gap: 18rpx;
}

.feed-author {
  color: #142033;
  font-size: 32rpx;
  font-weight: 650;
  line-height: 1.22;
}

.feed-meta {
  margin-top: 7rpx;
  color: #6B7280;
  font-size: 26rpx;
  font-weight: 400;
  line-height: 1.25;
}

.feed-title {
  margin-top: 22rpx;
  color: #142033;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.34;
}

.feed-body {
  margin-top: 14rpx;
  color: #6B7280;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.66;
}

.avatar,
.avatar-button {
  width: 64rpx;
  min-width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #7FBF4D;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
  box-shadow: 0 10rpx 24rpx rgba(127, 191, 77, 0.18);
}

.avatar.small {
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  font-size: 23rpx;
  line-height: 56rpx;
}

.avatar.large {
  width: 128rpx;
  min-width: 128rpx;
  height: 128rpx;
  border: 6rpx solid #FFFFFF;
  font-size: 44rpx;
  line-height: 128rpx;
}

.topic-pill,
.topic-pill.hot,
.mini-pill,
.mini-pill.green,
.mini-pill.orange {
  max-width: 190rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #F0F7ED;
  color: #3D7A2E;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.1;
}

.mini-pill.red {
  background: #FFF4F2;
  color: #B42318;
}

.post-actions {
  height: 44rpx;
  margin-top: 28rpx;
}

.post-action {
  height: 44rpx;
  min-width: 54rpx;
  margin-right: 34rpx;
  color: #0F8FBE;
}

.post-action-count,
.social-glyph {
  color: #0F8FBE;
}

.social-glyph {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
  font-size: 30rpx;
  line-height: 27rpx;
}

.post-action-count {
  font-size: 25rpx;
  font-weight: 650;
}

.post-action-press {
  background: rgba(15, 143, 190, 0.08);
  transform: scale(0.96);
}

.post-comment-bubble {
  border-color: #0F8FBE;
}

.post-comment-tail {
  border-left-color: #0F8FBE;
  border-bottom-color: #0F8FBE;
}

.section-title {
  color: #142033;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-note,
.subtitle,
.article-summary,
.utility-summary,
.profile-handle,
.profile-bio,
.profile-stat-label,
.card-footer,
.helper-text,
.panel-copy,
.quick-copy,
.course-name,
.planner-copy,
.empty-copy,
.loading-line {
  color: #6B7280;
}

.article-card,
.utility-card,
.web-panel,
.form-sheet,
.composer-sheet,
.profile-list {
  padding: 36rpx;
  border-radius: 40rpx;
}

.web-panel {
  margin: 0 44rpx 28rpx;
}

.quick-entry {
  min-height: 92rpx;
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 28rpx;
}

.quick-icon {
  color: #7FBF4D;
  font-size: 34rpx;
}

.quick-title,
.article-title,
.utility-title,
.profile-name,
.planner-title,
.course-code,
.empty-title,
.composer-name {
  color: #142033;
  font-weight: 700;
}

.spotlight-card,
.profile-cover,
.planner-hero,
.web-hero-card {
  background: linear-gradient(135deg, #7FBF4D 0%, #6DB344 100%);
  box-shadow: 0 18rpx 44rpx rgba(61, 122, 46, 0.12);
}

.profile-row {
  border-bottom-color: #E5EFE3;
}

.profile-row-label {
  color: #3D7A2E;
}

.text-input,
.text-area {
  border: 1rpx solid #E5EFE3;
  background: #FFFFFF;
  color: #142033;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.74);
}

.text-input:focus,
.text-area:focus,
.search-input:focus {
  border-color: rgba(127, 191, 77, 0.58);
  box-shadow: 0 0 0 6rpx rgba(127, 191, 77, 0.10);
}

.category-chip {
  padding: 14rpx 22rpx;
  border: 1rpx solid #E5EFE3;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #3D7A2E;
  font-size: 25rpx;
  font-weight: 600;
}

@supports (padding: env(safe-area-inset-bottom)) {
  .page-shell,
  .page-shell.feed-shell {
    padding-bottom: calc(224rpx + env(safe-area-inset-bottom));
  }
}
