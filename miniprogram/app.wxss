/* Feed post actions: no native button layout, no inherited pill styles. */
.post-actions {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
  height: 48rpx;
  margin-top: 22rpx;
  line-height: 1;
}

.post-action {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex: 0 0 auto;
  height: 48rpx;
  min-width: 62rpx;
  margin-right: 28rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  color: #2E7D52;
  line-height: 1;
}

.post-action:last-child {
  margin-right: 0;
}

.post-action-press {
  background: rgba(46, 125, 82, 0.10);
  transform: scale(0.94);
}

.post-action.is-liked {
  color: #e11d48;
  background: rgba(225, 29, 72, 0.08);
  animation: post-like-pop 360ms cubic-bezier(0.2, 1.4, 0.3, 1);
}

.social-glyph {
  display: block;
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
  color: #2E7D52;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 29rpx;
  text-align: center;
}

.like-glyph.filled {
  color: #e11d48;
  text-shadow: 0 8rpx 18rpx rgba(225, 29, 72, 0.24);
}

.post-action-count {
  color: #2E7D52;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.post-action.is-liked .social-glyph,
.post-action.is-liked .post-action-count {
  color: #e11d48;
}

.post-comment-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
  flex: 0 0 32rpx;
}

.post-comment-bubble {
  position: absolute;
  left: 3rpx;
  top: 5rpx;
  width: 26rpx;
  height: 20rpx;
  border: 4rpx solid #2E7D52;
  border-radius: 18rpx;
  box-sizing: border-box;
}

.post-comment-tail {
  position: absolute;
  left: 12rpx;
  top: 23rpx;
  width: 11rpx;
  height: 10rpx;
  border-left: 4rpx solid #2E7D52;
  border-bottom: 4rpx solid #2E7D52;
  border-bottom-left-radius: 4rpx;
  box-sizing: border-box;
  transform: rotate(-22deg);
}

@keyframes post-like-pop {
  0% {
    transform: scale(0.86);
  }
  58% {
    transform: scale(1.12);
  }
  100% {
    transform: scale(1);
  }
}

