page {
  min-height: 100%;
  background: #f4f2ec;
  color: #111813;
  font-size: 28rpx;
  line-height: 1.45;
}

button {
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  color: inherit;
  line-height: inherit;
  text-align: left;
}

button::after {
  border: none;
}

input,
textarea {
  color: #111813;
}

.page-shell {
  min-height: 100vh;
  padding: 20rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.page-shell.feed-shell {
  padding-left: 0;
  padding-right: 0;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 12rpx 24rpx 18rpx;
}

.top-bar.tight {
  padding-left: 0;
  padding-right: 0;
}

.brand-lockup {
  min-width: 0;
}

.eyebrow {
  color: #677066;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.app-title {
  color: #111813;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.12;
}

.app-title.compact {
  font-size: 36rpx;
}

.subtitle {
  margin-top: 8rpx;
  color: #687067;
  font-size: 24rpx;
}

.avatar,
.avatar-button {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #111813;
  color: #fffaf0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 800;
  overflow: hidden;
}

.avatar.small {
  width: 58rpx;
  height: 58rpx;
  font-size: 24rpx;
}

.avatar.large {
  width: 132rpx;
  height: 132rpx;
  border: 6rpx solid #fffaf0;
  font-size: 48rpx;
}

.avatar image,
.avatar-button image {
  width: 100%;
  height: 100%;
}

.avatar-button {
  box-shadow: 0 10rpx 24rpx rgba(17, 24, 19, 0.14);
}

.top-action {
  min-width: 112rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: #111813;
  color: #fffaf0;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.compose-card {
  margin: 0 24rpx 16rpx;
  padding: 22rpx;
  border: 2rpx solid #e2ddd2;
  border-radius: 28rpx;
  background: #fffaf0;
}

.compose-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.compose-placeholder {
  flex: 1;
  min-height: 70rpx;
  border-radius: 999rpx;
  background: #f3efe4;
  color: #747061;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 27rpx;
}

.compose-submit {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: #e45f2b;
  color: #fffaf0;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
}

.search-dock {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 0 24rpx 14rpx;
  padding: 0 20rpx;
  min-height: 76rpx;
  border-radius: 999rpx;
  background: #e9e4d8;
  box-sizing: border-box;
}

.search-dock.flat {
  margin-left: 0;
  margin-right: 0;
}

.search-mark {
  color: #7a766c;
  font-size: 28rpx;
  font-weight: 700;
}

.search-input {
  flex: 1;
  height: 76rpx;
  font-size: 26rpx;
}

.text-link {
  color: #e45f2b;
  font-size: 24rpx;
  font-weight: 700;
}

.segmented {
  display: flex;
  gap: 10rpx;
  padding: 8rpx;
  margin: 0 24rpx 16rpx;
  border-radius: 999rpx;
  background: #e9e4d8;
}

.segmented.flat {
  margin-left: 0;
  margin-right: 0;
}

.segment-item {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 999rpx;
  color: #676d64;
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
}

.segment-item.active {
  background: #111813;
  color: #fffaf0;
}

.feed-list {
  border-top: 2rpx solid #e6e0d5;
}

.feed-card {
  padding: 24rpx;
  border-bottom: 2rpx solid #e6e0d5;
  background: #fffaf0;
}

.feed-head {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.feed-main {
  flex: 1;
  min-width: 0;
}

.feed-author-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.feed-author {
  color: #111813;
  font-size: 27rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feed-meta {
  margin-top: 2rpx;
  color: #77766e;
  font-size: 22rpx;
}

.topic-pill {
  max-width: 176rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ecf5d8;
  color: #45611c;
  font-size: 21rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.topic-pill.hot {
  background: #ffe3d4;
  color: #a63e13;
}

.feed-title {
  margin-top: 14rpx;
  color: #111813;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
}

.feed-body {
  margin-top: 10rpx;
  color: #283029;
  font-size: 27rpx;
  line-height: 1.55;
  word-break: break-word;
}

.feed-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 18rpx;
  color: #6b7169;
}

.feed-action {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 999rpx;
  background: #f1ecdf;
  color: #687066;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.feed-action.is-active {
  background: #ffe3d4;
  color: #c14b1d;
}

.empty-state {
  margin: 20rpx 24rpx;
  padding: 54rpx 34rpx;
  border: 2rpx dashed #d6d0c4;
  border-radius: 28rpx;
  background: rgba(255, 250, 240, 0.72);
  text-align: center;
}

.empty-state.flat {
  margin-left: 0;
  margin-right: 0;
}

.empty-title {
  color: #111813;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-copy {
  margin-top: 10rpx;
  color: #727268;
  font-size: 25rpx;
}

.loading-line {
  padding: 26rpx;
  color: #747061;
  font-size: 24rpx;
  text-align: center;
}

.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin: 28rpx 0 14rpx;
}

.section-title {
  color: #111813;
  font-size: 32rpx;
  font-weight: 800;
}

.section-note {
  color: #73766b;
  font-size: 23rpx;
}

.spotlight-card {
  padding: 30rpx;
  border-radius: 30rpx;
  background: #1b2b21;
  color: #fffaf0;
  box-shadow: 0 18rpx 42rpx rgba(17, 24, 19, 0.16);
}

.spotlight-kicker {
  color: #f1bd78;
  font-size: 23rpx;
  font-weight: 800;
}

.spotlight-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.28;
}

.spotlight-summary {
  margin-top: 14rpx;
  color: #e9e5dc;
  font-size: 26rpx;
  line-height: 1.55;
}

.spotlight-footer {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
  color: #f1bd78;
  font-size: 23rpx;
}

.article-card,
.utility-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #e2ddd2;
  border-radius: 26rpx;
  background: #fffaf0;
}

.article-meta,
.utility-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.mini-pill {
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  background: #f0eadc;
  color: #676d64;
  font-size: 21rpx;
  font-weight: 800;
}

.mini-pill.green {
  background: #e8f5d0;
  color: #42600f;
}

.mini-pill.orange {
  background: #ffe4d0;
  color: #a74116;
}

.mini-pill.red {
  background: #ffe2df;
  color: #a12b24;
}

.article-title,
.utility-title {
  color: #111813;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1.35;
}

.article-summary,
.utility-summary {
  margin-top: 10rpx;
  color: #3c443d;
  font-size: 26rpx;
  line-height: 1.55;
}

.card-footer {
  margin-top: 16rpx;
  color: #70736a;
  font-size: 23rpx;
}

.inline-action {
  display: flex;
  margin-top: 18rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #111813;
  color: #fffaf0;
  font-size: 23rpx;
  font-weight: 800;
  text-align: center;
}

.profile-cover {
  height: 184rpx;
  margin: -20rpx -24rpx 0;
  background: linear-gradient(135deg, #1d2d23 0%, #415c2a 54%, #e45f2b 100%);
}

.profile-card {
  margin-top: -58rpx;
  padding: 0 24rpx 26rpx;
}

.profile-name {
  margin-top: 14rpx;
  color: #111813;
  font-size: 38rpx;
  font-weight: 900;
}

.profile-handle,
.profile-bio {
  margin-top: 6rpx;
  color: #687066;
  font-size: 25rpx;
}

.profile-bio {
  color: #333b34;
  line-height: 1.5;
}

.profile-stats {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}

.profile-stat {
  flex: 1;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #fffaf0;
}

.profile-stat-value {
  color: #111813;
  font-size: 30rpx;
  font-weight: 900;
}

.profile-stat-label {
  color: #727268;
  font-size: 22rpx;
}

.profile-list {
  margin-top: 20rpx;
  border-radius: 26rpx;
  background: #fffaf0;
  overflow: hidden;
}

.profile-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  border-bottom: 2rpx solid #eee7dc;
}

.profile-row:last-child {
  border-bottom: none;
}

.profile-row-label {
  color: #687066;
  flex-shrink: 0;
  font-size: 25rpx;
}

.profile-row-value {
  color: #111813;
  flex: 1;
  font-size: 25rpx;
  text-align: right;
  word-break: break-all;
}

.action-row {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.primary-action,
.secondary-action,
.danger-action,
.wechat-action {
  display: block;
  flex: 1;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
}

.primary-action {
  background: #111813;
  color: #fffaf0;
}

.secondary-action {
  background: #e9e4d8;
  color: #111813;
}

.danger-action {
  background: #ffe2df;
  color: #9f2c20;
}

.wechat-action {
  background: #07c160;
  color: #fff;
  margin-top: 22rpx;
}

.form-sheet > .wechat-action {
  width: 100%;
}

.form-sheet {
  padding: 26rpx;
  border-radius: 30rpx;
  background: #fffaf0;
}

.form-sheet + .form-sheet {
  margin-top: 18rpx;
}

.field-label {
  margin: 22rpx 0 10rpx;
  color: #5e665d;
  font-size: 24rpx;
  font-weight: 800;
}

.text-input,
.text-area {
  width: 100%;
  border-radius: 22rpx;
  background: #f1ecdf;
  box-sizing: border-box;
  font-size: 27rpx;
}

.text-input {
  height: 86rpx;
  padding: 0 22rpx;
}

.text-area {
  min-height: 230rpx;
  padding: 22rpx;
  line-height: 1.55;
}

.helper-text {
  margin-top: 14rpx;
  color: #73766b;
  font-size: 23rpx;
}

.category-strip {
  display: flex;
  gap: 12rpx;
  margin: 16rpx 0 22rpx;
  white-space: nowrap;
}

.category-chip {
  display: inline-flex;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: #f1ecdf;
  color: #646b62;
  font-size: 25rpx;
  font-weight: 800;
}

.category-chip.active {
  background: #e45f2b;
  color: #fffaf0;
}

.composer-sheet {
  padding: 24rpx;
  border-radius: 30rpx;
  background: #fffaf0;
}

.composer-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #eee7dc;
}

.composer-name {
  color: #111813;
  font-size: 27rpx;
  font-weight: 850;
}

.composer-scope {
  color: #73766b;
  font-size: 23rpx;
}

/* UI preview refresh: align native Mini Program with the web glass design. */
page {
  background: linear-gradient(180deg, #ffffff 0%, #f7fbf8 100%);
  color: #123021;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  box-sizing: border-box;
}

.page-shell {
  padding: 28rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.page-shell.feed-shell {
  padding-left: 0;
  padding-right: 0;
}

.top-bar {
  padding: 28rpx 28rpx 22rpx;
}

.top-bar.tight {
  padding-left: 0;
  padding-right: 0;
}

.eyebrow {
  color: #2E7D52;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.app-title,
.app-title.compact {
  color: #123021;
  font-weight: 950;
  letter-spacing: 0;
}

.subtitle {
  color: #667085;
}

.avatar,
.avatar-button {
  width: 76rpx;
  min-width: 76rpx;
  height: 76rpx;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2E7D52, #78A22F);
  color: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(46, 125, 82, 0.18);
  box-sizing: border-box;
  line-height: 76rpx;
}

.avatar-button {
  flex: 0 0 76rpx;
  margin: 0;
  text-align: center;
}

.avatar.small {
  width: 60rpx;
  min-width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
}

.avatar.large {
  background: #2E7D52;
  border: 6rpx solid rgba(255, 255, 255, 0.84);
}

.compose-card,
.article-card,
.utility-card,
.profile-stat,
.profile-list,
.form-sheet,
.composer-sheet,
.empty-state,
.home-loading,
.home-empty {
  border: 2rpx solid rgba(46, 125, 82, 0.14);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(247, 251, 248, 0.78));
  box-shadow:
    0 18rpx 46rpx rgba(46, 125, 82, 0.10),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.82);
}

.compose-card {
  margin: 0 28rpx 18rpx;
  border-radius: 28rpx;
}

.compose-placeholder,
.search-dock,
.segmented,
.text-input,
.text-area,
.category-chip {
  border: 2rpx solid rgba(46, 125, 82, 0.12);
  background: rgba(238, 247, 240, 0.9);
}

.compose-submit,
.primary-action,
.top-action,
.inline-action,
.wechat-action {
  background: #0052CC;
  color: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(0, 102, 204, 0.20);
}

.secondary-action,
.feed-action {
  background: rgba(238, 247, 240, 0.92);
  color: #2E7D52;
}

.danger-action {
  background: #fef2f2;
  color: #b42318;
}

.search-dock {
  margin: 0 28rpx 16rpx;
  min-height: 84rpx;
  border-radius: 999rpx;
  color: #2E7D52;
}

.search-dock.flat,
.segmented.flat {
  margin-left: 0;
  margin-right: 0;
}

.search-mark,
.text-link {
  color: #2E7D52;
}

.segmented {
  margin: 0 28rpx 18rpx;
  padding: 8rpx;
  background: rgba(238, 247, 240, 0.9);
}

.segment-item {
  color: #2E7D52;
}

.segment-item.active,
.category-chip.active {
  background: #2E7D52;
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(46, 125, 82, 0.18);
}

.feed-list {
  border-top: 0;
  padding: 0 28rpx;
}

.feed-card {
  margin-bottom: 18rpx;
  padding: 26rpx;
  border: 2rpx solid rgba(46, 125, 82, 0.14);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 46rpx rgba(46, 125, 82, 0.10);
}

.feed-author,
.feed-title,
.article-title,
.utility-title,
.section-title,
.profile-name,
.profile-stat-value,
.composer-name {
  color: #123021;
}

.feed-meta,
.article-summary,
.utility-summary,
.profile-handle,
.profile-bio,
.profile-stat-label,
.card-footer,
.helper-text {
  color: #667085;
}

.topic-pill,
.mini-pill.green {
  background: #e8f5e9;
  color: #2E7D52;
}

.topic-pill.hot,
.mini-pill.orange {
  background: #e8f5e9;
  color: #2E7D52;
}

.mini-pill.red {
  background: #fef2f2;
  color: #b42318;
}

.feed-action.is-active {
  background: #e8f5e9;
  color: #2E7D52;
}

.spotlight-card {
  background: #2E7D52;
  box-shadow: 0 24rpx 54rpx rgba(46, 125, 82, 0.18);
}

.spotlight-kicker,
.spotlight-footer {
  color: #dff3e7;
}

.profile-cover {
  background: #2E7D52;
}

.profile-card {
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.profile-row {
  border-bottom-color: rgba(46, 125, 82, 0.10);
}

.profile-row-label {
  color: #2E7D52;
}

.profile-row-value {
  color: #123021;
}

.loading-line {
  color: #667085;
}

@supports (padding: env(safe-area-inset-bottom)) {
  .page-shell {
    padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
  }
}

/* Web-mobile parity layer for the native Mini Program preview. */
page {
  background: linear-gradient(180deg, #ffffff 0%, #f7fbf8 58%, #ffffff 100%);
}

.page-shell {
  padding: 34rpx 30rpx 260rpx;
}

.page-shell.feed-shell {
  padding-left: 0;
  padding-right: 0;
  padding-bottom: 260rpx;
}

.top-bar {
  padding: 36rpx 30rpx 24rpx;
}

.top-bar.tight {
  padding-top: 44rpx;
}

.eyebrow {
  color: #2E7D52;
  font-size: 22rpx;
  font-weight: 950;
  letter-spacing: 4rpx;
}

.app-title {
  color: #1f2937;
  font-size: 54rpx;
  font-weight: 950;
  letter-spacing: 0;
}

.app-title.compact {
  font-size: 42rpx;
}

.subtitle {
  max-width: 620rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.compose-card,
.search-dock,
.segmented,
.article-card,
.utility-card,
.web-panel,
.form-sheet,
.composer-sheet,
.empty-state,
.profile-list,
.profile-stat {
  border: 2rpx solid rgba(46, 125, 82, 0.14);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 251, 248, 0.76));
  box-shadow:
    0 20rpx 54rpx rgba(46, 125, 82, 0.11),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.88);
}

.compose-card {
  margin: 0 30rpx 18rpx;
  padding: 22rpx;
  border-radius: 32rpx;
}

.compose-placeholder,
.text-input,
.text-area {
  background: rgba(238, 247, 240, 0.92);
  border: 2rpx solid rgba(46, 125, 82, 0.10);
}

.compose-submit,
.top-action,
.primary-action,
.inline-action,
.web-primary-btn,
.wechat-action {
  border-radius: 999rpx;
  background: #0052CC;
  color: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(0, 102, 204, 0.22);
  text-align: center;
}

.search-dock {
  margin: 0 30rpx 16rpx;
  min-height: 84rpx;
