<section class="today-widget" aria-label="Today at HKMU">
  <article class="today-slide news active">
    <div class="today-top">
      <span class="today-label">School News</span>
      <span class="today-time">Today 09:00</span>
    </div>

    <div class="today-body">
      <h2>AI Career Sharing starts this afternoon</h2>
      <p>Block C lecture hall opens at 13:45. Students from DSAI and Computing are already joining.</p>

      <div class="today-detail">
        <div class="today-row">
          <span class="today-row-icon">👥</span>
          <div>
            <strong>32 going</strong>
            <span>6 classmates from your courses</span>
          </div>
        </div>
      </div>
    </div>

    <div class="today-bottom">
      <button class="today-action">View news</button>
      <div class="today-dots"></div>
    </div>
  </article>

  <article class="today-slide schedule">
    <div class="today-top">
      <span class="today-label">My Schedule</span>
      <span class="today-time">Today 11:30</span>
    </div>

    <div class="today-body">
      <h2>STAT2520SEF tutorial in 30 minutes</h2>
      <p>Your next class is in Block A. The system can also show exams and custom activities here.</p>

      <div class="today-detail">
        <div class="today-row">
          <span class="today-row-icon">📍</span>
          <div>
            <strong>Room A0412</strong>
            <span>Reminder set for 10 minutes before</span>
          </div>
        </div>

        <div class="today-row">
          <span class="today-row-icon">📘</span>
          <div>
            <strong>Quiz on Friday</strong>
            <span>Revision group available tonight</span>
          </div>
        </div>
      </div>
    </div>

    <div class="today-bottom">
      <button class="today-action">Open planner</button>
      <div class="today-dots"></div>
    </div>
  </article>

  <article class="today-slide club">
    <div class="today-top">
      <span class="today-label">Club Reminder</span>
      <span class="today-time">Tonight 18:30</span>
    </div>

    <div class="today-body">
      <h2>AI Club prototype night</h2>
      <p>Bring your laptop and join a small team. Good for students looking for project teammates.</p>

      <div class="today-detail">
        <div class="today-row">
          <span class="today-row-icon">✨</span>
          <div>
            <strong>Project teammate match</strong>
            <span>3 teams still looking for members</span>
          </div>
        </div>
      </div>
    </div>

    <div class="today-bottom">
      <button class="today-action">Join group</button>
      <div class="today-dots"></div>
    </div>
  </article>
</section>
.today-widget {
  width: 100%;
  max-width: 360px;
  aspect-ratio: 3 / 4;
  border-radius: 8px;
  overflow: hidden;
  position: relative;
  background: #08111f;
  box-shadow: 0 22px 54px rgba(15, 23, 42, 0.18);
  color: white;
}

.today-slide {
  position: absolute;
  inset: 0;
  padding: 22px;
  display: flex;
  flex-direction: column;
  opacity: 0;
  transform: translateX(20px);
  transition: opacity 0.36s ease, transform 0.36s ease;
  background: linear-gradient(160deg, #0f766e, #2563eb);
}

.today-slide.active {
  opacity: 1;
  transform: translateX(0);
  z-index: 2;
}

.today-slide.news {
  background: linear-gradient(160deg, #0f766e, #2563eb);
}

.today-slide.schedule {
  background: linear-gradient(160deg, #1d4ed8, #7c3aed);
}

.today-slide.club {
  background: linear-gradient(160deg, #b45309, #be123c);
}

.today-slide::after {
  content: "";
  position: absolute;
  width: 220px;
  height: 220px;
  right: -80px;
  top: -70px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.today-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 28px;
}

.today-label {
  display: inline-flex;
  align-items: center;
  border: 1px solid rgba(255, 255, 255, 0.28);
  background: rgba(255, 255, 255, 0.14);
  border-radius: 999px;
  padding: 8px 11px;
  font-size: 12px;
  font-weight: 800;
}

.today-time {
  color: rgba(255, 255, 255, 0.72);
  font-size: 12px;
  font-weight: 700;
}

.today-body {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.today-body h2 {
  font-size: 30px;
  line-height: 1.1;
  font-weight: 800;
  margin: 0 0 12px;
}

.today-body p {
  margin: 0;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.6;
  font-size: 14px;
}

.today-detail {
  margin-top: 22px;
  display: grid;
  gap: 10px;
}

.today-row {
  display: grid;
  grid-template-columns: 38px 1fr;
  gap: 10px;
  align-items: center;
  border: 1px solid rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.12);
  border-radius: 8px;
  padding: 10px;
}

.today-row-icon {
  width: 38px;
  height: 38px;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.2);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.today-row strong {
  display: block;
  font-size: 13px;
  margin-bottom: 2px;
}

.today-row span {
  display: block;
  color: rgba(255, 255, 255, 0.72);
  font-size: 12px;
}

.today-bottom {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.today-action {
  border: 0;
  border-radius: 8px;
  padding: 10px 13px;
  background: white;
  color: #1d4ed8;
  font-weight: 800;
  cursor: pointer;
}

.today-dots {
  display: flex;
  gap: 6px;
}

.today-dot {
  width: 8px;
  height: 8px;
  border: 0;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.32);
  cursor: pointer;
  transition: width 0.2s ease, background 0.2s ease;
}

.today-dot.active {
  width: 24px;
  background: white;
}
